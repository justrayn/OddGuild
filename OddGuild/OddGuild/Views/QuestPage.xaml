<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:OddGuild.ViewModels"
             x:Class="OddGuild.Views.QuestPage"
             Title="Quests"
             BackgroundColor="#1C1512"> <ContentPage.BindingContext>
        <viewmodels:QuestViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="Auto, *" Padding="15">

        <Frame Grid.Row="0" 
               BackgroundColor="#2A1F1A" 
               BorderColor="#C45A1D" 
               CornerRadius="10" 
               Padding="15" 
               Margin="0,0,0,20">
            <VerticalStackLayout Spacing="10">
                
                <Label Text="SEARCH SCROLL" TextColor="#C45A1D" FontAttributes="Bold" FontSize="12" />
                
                <Frame BackgroundColor="#E6DCC3" CornerRadius="5" Padding="5,0" HasShadow="False">
                    <SearchBar Placeholder="Keywords..." 
                               Text="{Binding SearchQuery}" 
                               CancelButtonColor="Black" 
                               TextColor="Black" 
                               PlaceholderColor="DimGray"/>
                </Frame>

                <Grid ColumnDefinitions="*, Auto">
                    <Label Grid.Column="0" Text="MIN BOUNTY" TextColor="#C45A1D" FontAttributes="Bold" FontSize="12" VerticalOptions="Center"/>
                    <Label Grid.Column="1" Text="{Binding MinimumBounty, StringFormat='{0}G'}" TextColor="#E6DCC3" FontAttributes="Bold" FontSize="12" VerticalOptions="Center"/>
                </Grid>
                
                <Slider Minimum="0" Maximum="5000" Value="{Binding MinimumBounty}" MinimumTrackColor="#3B82F6" MaximumTrackColor="#E6DCC3" />
            
            </VerticalStackLayout>
        </Frame>

        <CollectionView Grid.Row="1" ItemsSource="{Binding AvailableQuests}">
            
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="2" HorizontalItemSpacing="15" VerticalItemSpacing="15" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BackgroundColor="#DAC7A7" CornerRadius="2" Padding="12" HasShadow="True">
                        <VerticalStackLayout Spacing="5">
                            
                            <Grid ColumnDefinitions="*, Auto">
                                <Label Grid.Column="0" Text="ODD GUILD" TextColor="#8C8371" FontSize="10" FontAttributes="Bold" />
                                <Label Grid.Column="1" Text="{Binding Id, StringFormat='NO. {0}'}" TextColor="#8C8371" FontSize="10" />
                            </Grid>

                            <BoxView HeightRequest="1" Color="#8C8371" Opacity="0.3" Margin="0,5" />

                            <Label Text="{Binding Type}" TextColor="#4A3F35" FontSize="12" FontAttributes="Bold" />
                            <Label Text="{Binding Title}" TextColor="#A63A24" FontSize="14" FontAttributes="Bold" />

                            <Label Text="☕" FontSize="30" HorizontalOptions="Center" Margin="0,10" />

                            <Label Text="{Binding Description}" TextColor="#4A3F35" FontSize="10" FontAttributes="Italic" LineBreakMode="WordWrap" />

                            <BoxView HeightRequest="1" Color="#8C8371" Opacity="0.3" Margin="0,5" />

                            <Label Text="{Binding Bounty, StringFormat='{0} G'}" TextColor="#2A1F1A" FontSize="14" FontAttributes="Bold" HorizontalOptions="Center" />
                            <Label Text="💀" FontSize="12" HorizontalOptions="Center" />

                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>