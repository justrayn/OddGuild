<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:OddGuild.ViewModels"
             x:Class="OddGuild.Views.QuestPage"
             Title="Quests"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#1C1512"> 

    <ContentPage.BindingContext>
        <viewmodels:QuestViewModel />
    </ContentPage.BindingContext>
    <ContentPage.Resources>
        <Style TargetType="Label">
            <Setter Property="FontFamily" Value="PixelifyBold" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="PixelifyBold" />
        </Style>
    </ContentPage.Resources>
    <Grid RowDefinitions="Auto, *">

        <Grid Grid.Row="0" BackgroundColor="#2D1E16" Padding="15, 20, 15, 25">
            <Grid HorizontalOptions="Start" VerticalOptions="Start">
                <BoxView WidthRequest="20" HeightRequest="3" Color="#C45A1D" HorizontalOptions="Start" VerticalOptions="Start" CornerRadius="2"/>
                <BoxView WidthRequest="3" HeightRequest="20" Color="#C45A1D" HorizontalOptions="Start" VerticalOptions="Start" CornerRadius="2"/>
            </Grid>

            <Grid HorizontalOptions="End" VerticalOptions="Start">
                <BoxView WidthRequest="20" HeightRequest="3" Color="#C45A1D" HorizontalOptions="End" VerticalOptions="Start" CornerRadius="2"/>
                <BoxView WidthRequest="3" HeightRequest="20" Color="#C45A1D" HorizontalOptions="End" VerticalOptions="Start" CornerRadius="2"/>
            </Grid>

            <VerticalStackLayout HorizontalOptions="Center" Spacing="0">
                <Label Text="ODD" TextColor="#D3A052" FontSize="36" FontAttributes="Bold" HorizontalOptions="Center" CharacterSpacing="2" />
                <Label Text="GUILD" TextColor="#D3A052" FontSize="36" FontAttributes="Bold" HorizontalOptions="Center" CharacterSpacing="2" />
                
                <Grid ColumnDefinitions="*, Auto, *" ColumnSpacing="15" Margin="0,15,0,0">
                    <BoxView Grid.Column="0" HeightRequest="2" Color="#C45A1D" VerticalOptions="Center" />
                    <Label Grid.Column="1" Text="TAGLINE" TextColor="#C45A1D" FontSize="14" FontAttributes="Bold" CharacterSpacing="1" />
                    <BoxView Grid.Column="2" HeightRequest="2" Color="#C45A1D" VerticalOptions="Center" />
                </Grid>
            </VerticalStackLayout>
        </Grid>


        <Grid Grid.Row="1" RowDefinitions="Auto, Auto, *" Padding="15, 20, 15, 0">
            
            <Border Grid.Row="0" 
                    BackgroundColor="#2A1F1A" 
                    Stroke="#C45A1D" 
                    StrokeThickness="1"
                    Padding="15" 
                    Margin="0,0,0,15">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                
                <VerticalStackLayout Spacing="10">
                    
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Grid.Column="0" Text="SEARCH SCROLL" TextColor="#C45A1D" FontAttributes="Bold" FontSize="12" VerticalOptions="Center" />
                        
                        <Border Grid.Column="1" 
                                BackgroundColor="#C45A1D" 
                                Stroke="Transparent"
                                Padding="8,0" 
                                HeightRequest="24"
                                VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="4" />
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,2" Opacity="0.3" />
                            </Border.Shadow>
                            
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer />
                            </Border.GestureRecognizers>

                            <HorizontalStackLayout Spacing="3" VerticalOptions="Center" HorizontalOptions="Center">
                                <Label Text="+" FontSize="16" FontAttributes="Bold" TextColor="#2D1E16" VerticalTextAlignment="Center" Margin="0,-2,0,0" />
                                <Label Text="POST QUEST" FontSize="10" FontAttributes="Bold" TextColor="#2D1E16" VerticalTextAlignment="Center" />
                            </HorizontalStackLayout>
                        </Border>
                    </Grid>
                    
                    <Border BackgroundColor="#E6DCC3" Stroke="Transparent" Padding="5,0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="5" />
                        </Border.StrokeShape>
                        <SearchBar Placeholder="Keywords..." 
                                   Text="{Binding SearchQuery}" 
                                   CancelButtonColor="Black" 
                                   TextColor="Black" 
                                   PlaceholderColor="DimGray"/>
                    </Border>

                    <Grid ColumnDefinitions="*, Auto">
                        <Label Grid.Column="0" Text="MIN BOUNTY" TextColor="#C45A1D" FontAttributes="Bold" FontSize="12" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="{Binding MinimumBounty, StringFormat='{0}G'}" TextColor="#E6DCC3" FontAttributes="Bold" FontSize="12" VerticalOptions="Center"/>
                    </Grid>
                    
                    <Slider Minimum="0" Maximum="5000" Value="{Binding MinimumBounty}" MinimumTrackColor="#3B82F6" MaximumTrackColor="#E6DCC3" />
                </VerticalStackLayout>
            </Border>

            <Grid Grid.Row="1" ColumnDefinitions="Auto, Auto, *" ColumnSpacing="15" Margin="0,0,0,15">
                
                <VerticalStackLayout Grid.Column="0" Spacing="4">
                    <Label Text="General Quests" TextColor="#C45A1D" FontAttributes="Bold" FontSize="14" />
                    <BoxView HeightRequest="2" Color="#C45A1D" CornerRadius="1" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1" Spacing="4">
                    <Label Text="My Posted Quests" TextColor="#8C8371" FontAttributes="Bold" FontSize="14" />
                </VerticalStackLayout>
                
                <BoxView Grid.ColumnSpan="3" HeightRequest="1" Color="#8C8371" Opacity="0.3" VerticalOptions="End" />
            </Grid>

            <CollectionView Grid.Row="2" ItemsSource="{Binding AvailableQuests}">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="2" HorizontalItemSpacing="15" VerticalItemSpacing="15" />
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="#DAC7A7" Stroke="Transparent" Padding="12">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="2" />
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,2" Opacity="0.2" />
                            </Border.Shadow>
                            
                            <VerticalStackLayout Spacing="5">
                                <Grid ColumnDefinitions="*, Auto">
                                    <Label Grid.Column="0" Text="ODD GUILD" TextColor="#8C8371" FontSize="10" FontAttributes="Bold" />
                                    <Label Grid.Column="1" Text="{Binding Id, StringFormat='NO. {0}'}" TextColor="#8C8371" FontSize="10" />
                                </Grid>

                                <BoxView HeightRequest="1" Color="#8C8371" Opacity="0.3" Margin="0,5" />

                                <Label Text="{Binding Type}" TextColor="#4A3F35" FontSize="12" FontAttributes="Bold" />
                                <Label Text="{Binding Title}" TextColor="#A63A24" FontSize="14" FontAttributes="Bold" />

                                <Label Text="☕" FontSize="30" HorizontalOptions="Center" Margin="0,10" />

                                <Label Text="{Binding Description}" TextColor="#4A3F35" FontSize="10" FontAttributes="Italic" LineBreakMode="WordWrap" />

                                <BoxView HeightRequest="1" Color="#8C8371" Opacity="0.3" Margin="0,5" />

                                <Label Text="{Binding Bounty, StringFormat='{0} G'}" TextColor="#2A1F1A" FontSize="14" FontAttributes="Bold" HorizontalOptions="Center" />
                                <Label Text="💀" FontSize="12" HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </Grid>
    </Grid>
</ContentPage>