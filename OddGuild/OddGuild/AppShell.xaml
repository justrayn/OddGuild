<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="OddGuild.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:OddGuild.Views"
    Title="OddGuild"
    
    Shell.TabBarBackgroundColor="#2D1E16"
    Shell.TabBarTitleColor="#C45A1D"
    Shell.TabBarUnselectedColor="#8C8371">

    <Shell.Resources>
        <Style TargetType="TabBar">
            <Setter Property="Shell.TabBarBackgroundColor" Value="#2D1E16" />
        </Style>
    </Shell.Resources>

    <TabBar>
        
        <Tab Title="Home" Icon="icon_home.png">
            <ShellContent ContentTemplate="{DataTemplate views:HomePage}" />
        </Tab>

        <Tab Title="Quests" Icon="icon_quests.png">
            <ShellContent ContentTemplate="{DataTemplate views:QuestPage}" />
        </Tab>

        <Tab Title="Party" Icon="icon_party.png">
            <ShellContent ContentTemplate="{DataTemplate views:PartyPage}" />
        </Tab>

        <Tab Title="Profile" Icon="icon_profile.png">
            <ShellContent ContentTemplate="{DataTemplate views:ProfilePage}" />
        </Tab>

    </TabBar>

</Shell>