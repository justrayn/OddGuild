<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="OddGuild.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:OddGuild.Views"
    Title="OddGuild"
    
    Shell.TabBarBackgroundColor="#1C1512"
    Shell.TabBarTitleColor="#C45A1D"
    Shell.TabBarUnselectedColor="Gray">

    <TabBar>
        
        <Tab Title="Home">
            <ShellContent ContentTemplate="{DataTemplate views:MainPage}" />
        </Tab>

        <Tab Title="Quests">
            <ShellContent ContentTemplate="{DataTemplate views:QuestPage}" />
        </Tab>

    </TabBar>

</Shell>